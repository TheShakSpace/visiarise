PORT=5000
MONGO_URI=mongodb://localhost:27017/visiarise
JWT_SECRET=change-me-to-a-long-random-string
MESHY_API_KEY=

CLIENT_URL=http://localhost:5173

# Credits (app-side; Meshy bills your API key separately)
DEFAULT_SIGNUP_CREDITS=100
CREDIT_COST_MESHY_PREVIEW=5
CREDIT_COST_MESHY_REFINE=10

# First account matching this email becomes admin (unlimited Meshy credit checks + grant UI)
ADMIN_EMAIL=
ADMIN_INITIAL_CREDITS=999999

# Nodemailer (optional — signup still works if SMTP fails; check server logs for OTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
