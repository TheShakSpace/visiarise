# macOS: port 5000 is often AirPlay Receiver (403 + Server: AirTunes). Use 5001 and add PORT=5001 to the repo root .env so Vite’s /api proxy matches.
PORT=5000
MONGO_URI=
JWT_SECRET=change-me-to-a-long-random-string
MESHY_API_KEY=

CLIENT_URL=http://localhost:5173

# Credits (app-side; Meshy bills your API key separately)
DEFAULT_SIGNUP_CREDITS=100
# Optional signup promo — matched code is stored on the user server-side (referralCodeApplied, select:false)
REFERRAL_MASTER_CODE=AdminDhruv100%
REFERRAL_BONUS_CREDITS=500
CREDIT_COST_MESHY_PREVIEW=5
CREDIT_COST_MESHY_REFINE=10

# First account matching this email becomes admin (unlimited Meshy credit checks + grant UI)
ADMIN_EMAIL=
ADMIN_INITIAL_CREDITS=999999

# Hostinger SMTP (port 465 = SSL). Quote EMAIL_PASS if it contains % or spaces.
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
# Inbox for public contact form (defaults to EMAIL_FROM or EMAIL_USER)
CONTACT_TO=
